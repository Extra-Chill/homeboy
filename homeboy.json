    "test_wiring": {
      "policies": [
        {
          "auto_discovered_test_path_globs": [
            "tests/*_test.rs"
          ],
          "convention": "test_wiring",
          "description": "Nested test file `{test_path}` is not wired into the configured test harness",
          "explicit_wiring_marker_patterns": [
            "{test_path}"
          ],
          "id": "nested-test-harness-wiring",
          "require_explicit_wiring": true,
          "severity": "warning",
          "source_path_globs": [
            "src/**/*.rs"
          ],
          "suggestion": "Wire `{test_path}` from the covered source module with an explicit path include, or move it to a top-level auto-discovered test path.",
          "support_test_path_globs": [],
          "test_path_globs": [
            "tests/**/*_test.rs"
          ]
        }
      ]
