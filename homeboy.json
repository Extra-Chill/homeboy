    "thin_command_adapter": {
      "allow_line_contains": [
        "homeboy-audit: allow-thin-command-adapter"
      ],
      "file_extensions": [
        "rs"
      ],
      "ignore_after_line_equals": [
        "#[cfg(test)]"
      ],
      "ignore_line_matches": [
        "^\\s*(pub(\\([^)]*\\))?\\s+)?(async\\s+)?fn\\s"
      ],
      "ignore_line_prefixes": [
        "//",
        "///",
        "//!"
      ],
      "include_path_contains": [
        "src/commands/"
      ],
      "max_orchestration_weight": 3,
      "orchestration_markers": [
        {
          "label": "direct process execution",
          "patterns": [
            "\\bstd::process::Command\\b",
            "\\bCommand::new\\s*\\("
          ]
        },
        {
          "label": "direct filesystem mutation",
          "patterns": [
            "\\b(std::fs|fs)::(write|create_dir|create_dir_all|remove_file|remove_dir|remove_dir_all|rename|copy)\\s*\\("
          ]
        },
        {
          "label": "direct file writer construction",
          "patterns": [
            "\\b(File::create|OpenOptions::new)\\s*\\("
          ]
        },
        {
          "exempt_when_line_matches": [
            "[A-Za-z_][A-Za-z0-9_]*::(dispatch|execute|persist)[A-Za-z0-9_]*\\s*\\("
          ],
          "label": "run artifact persistence",
          "patterns": [
            "\\b(RunDir::create|write_to_run_dir|ObservationBuilder|finish_run|persist_[A-Za-z0-9_]+)\\b"
          ]
        },
        {
          "exempt_when_line_matches": [
            "[A-Za-z_][A-Za-z0-9_]*::(dispatch|execute|persist)[A-Za-z0-9_]*\\s*\\("
          ],
          "label": "runner execution orchestration",
          "patterns": [
            "\\b(runner::exec|execute_[A-Za-z0-9_]+|dispatch_[A-Za-z0-9_]+)\\s*\\("
          ]
        }
      ]
    }
